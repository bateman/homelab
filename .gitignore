# =============================================================================
# Homelab - Git Ignore
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets and Local Configuration
# -----------------------------------------------------------------------------
# Credential files - NEVER commit!
docker/.env
docker/.env.secrets

# Authelia secrets (JWT, session, encryption keys)
docker/secrets/

# Locally generated TLS certificates
docker/config/traefik/certs/

# -----------------------------------------------------------------------------
# Service Configurations (generated at runtime)
# -----------------------------------------------------------------------------
# Service configs contain API keys and sensitive data
# Backed up via Duplicati, not via Git
docker/config/*/

# Exception: keep static Traefik configuration files
!docker/config/traefik/
docker/config/traefik/certs/

# Exception: keep cert download page (HTML template only, not generated files)
!docker/config/cert-page/
docker/config/cert-page/ca.crt
docker/config/cert-page/homelab.mobileconfig

# Exception: keep Authelia configuration templates
!docker/config/authelia/
# But ignore runtime files and user-customized configs
docker/config/authelia/users_database.yml
docker/config/authelia/db.sqlite3
docker/config/authelia/notification.txt

# Exception: keep Home Assistant configuration templates
!docker/config/homeassistant/
docker/config/homeassistant/.HA_VERSION
docker/config/homeassistant/.ha_run.lock
docker/config/homeassistant/.storage/
docker/config/homeassistant/blueprints/
docker/config/homeassistant/home-assistant.log*
docker/config/homeassistant/home-assistant_v2.db*
docker/config/homeassistant/automations.yaml
docker/config/homeassistant/scenes.yaml
docker/config/homeassistant/scripts.yaml
docker/config/homeassistant/secrets.yaml

# Exception: keep Pi-hole adlists file (blocklist URLs for bulk import)
!docker/config/pihole/
docker/config/pihole/etc-pihole/
docker/config/pihole/etc-dnsmasq.d/

# -----------------------------------------------------------------------------
# System Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Logs and Cache
# -----------------------------------------------------------------------------
*.log
*.cache
__pycache__/
